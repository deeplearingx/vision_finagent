# ── Milvus 连接 ──────────────────────────────────────────────────────────────
# 本地 Lite 模式（默认，不需要设置 MILVUS_URI）：
# MILVUS_URI=./milvus_local.db

# Zilliz Cloud 云端模式（填入控制台 Public Endpoint 和 API Token）：
# MILVUS_URI=https://in03-xxxxxxxxxxxxxxxxx.serverless.gcp-us-west1.cloud.zilliz.com
# MILVUS_TOKEN=your_zilliz_api_token_here
# MILVUS_DB_NAME=default

# 自建 Milvus Standalone（无认证）：
# MILVUS_URI=http://your-host:19530

MILVUS_COLLECTION=fin_vision_reports
# Zilliz Cloud 单次 search 的 nq 上限为 10；自建 Milvus 可调大（如 64）
# MILVUS_NQ_BATCH=10
REDIS_URL=redis://localhost:6379/0

# ── 模型路径 ──────────────────────────────────────────────────────────────────
MODEL_PATH=vidore/colpali-v1.2
# 当 MODEL_PATH 是 LoRA adapter 目录时，必须同时设置 BASE_MODEL_PATH：
# BASE_MODEL_PATH=/root/autodl-tmp/colpaligemma-3b-pt-448-base

# ── VLM API ───────────────────────────────────────────────────────────────────
VLM_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
VLM_MODEL=Kimi-K2.6
VLM_API_KEY=your-api-key-here

# ── 其他 ──────────────────────────────────────────────────────────────────────
MAX_BATCH_SIZE=4
LOG_LEVEL=INFO
IDEMPOTENCY_TTL=86400
